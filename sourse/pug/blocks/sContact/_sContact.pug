						span  events@ruvents.com
					+e.item
						+icon("web")
						span 127055&nbsp;г. Москва, ул. Образцова д.7 подъезд 3, 3&nbsp;этаж
					.mt-4.pt-3.border-top(class="sContact__requisites")
						p.mb-1
							strong Полное наименование:
							| ООО "РУВЕНТС"
						p.mb-1
							strong ИНН:
							| 7703806326
						p.mb-1
							strong КПП:
							| 770301001
						p.mb-1
							strong ОГРН:
							| 1147746069964
					.row.mt-3
						//- .col-lg.col-auto
						//- 	+e.item 
						//- 		div
						//- 			.strong.mb-2 Секретариат:
									
						//- 			a.body-color(href="tel:+7(495)950-56-51") +7 (495) 950-56-51
						.col-auto
							+e.item 
								div
									.strong.mb-2  По вопросам закрывающих документов:
									
									| #[a.body-color.mb-2(href="tel:+7(495)109-02-00p3") +7 (495) 109-02-00, доб. 3] 
									br
									| #[a(href="mailto:fin@ruvents.com") fin@ruvents.com ] 
						//- .col-auto
						//- 	+e.item 
						//- 		div
						//- 			.strong.mb-2 Представительство в Узбекистане:
						//- 			p.small OOO «INFOCOM OVERSEAS»
						//- 				br
						//- 				| Резидент IT-Парк, г. Ташкент
						//- 				br
						//- 				| г. Ташкент, Мирзо-Улугбекский район, улица Лашкарбеги (Окай-Сити)
									
						//- 			| #[a.body-color.mb-2(href="tel:+998900479331") +998 90 0479331] 

				.col-xxl-auto.col-xl-6( class="wow fadeInUp"  data-wow-delay=`${delay + .2}s` data-wow-duration=`${dur }s`)
					+e.logo
						img(loading="lazy" src="img/svg/logo.svg", alt="RUVENTS")
					+e.map-wrap( class="wow fadeIn "  data-wow-delay=`${delay/2 }s` data-wow-duration=`${dur }s`   )
