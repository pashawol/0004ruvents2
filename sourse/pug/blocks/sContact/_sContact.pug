			+e.footer( class="wow  fadeInUp" data-wow-delay=`${delay + .2}s` data-wow-duration=`${dur }s`)
				.row.align-items-center
					.col-md-6.h5.strong.m-0( style="opacity: 0.2;") © #[strong ООО «РУВЕНТС» 2014-#[span.current-year 2026]]
					.col-md-6.text-end
