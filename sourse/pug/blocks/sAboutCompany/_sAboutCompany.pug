mixin sAboutCompany()
	// start sAboutCompany
	section#sAboutCompany.sAboutCompany.section
		.container
			.section-title.text-center.mb-2
				h2.wow.fadeInUp О RUVENTS
				p.lead.wow.fadeInUp(data-wow-delay="0.2s") Один из крупнейших российских разработчиков и интегратор ИТ-решений для мероприятий и бизнеса.
			.row.align-items-center
				.col-lg-6.wow.fadeInLeft(data-wow-delay="0.4s")
					h3(style="color: #3d58b0; margin-bottom: 1.5rem;") Инновации и надежность
					p ООО &quot;РУВЕНТС&quot; – это команда высококвалифицированных ИТ-специалистов, создающая передовые программные продукты и сервисы. Мы специализируемся на разработке комплексных информационных систем, веб-порталов, мобильных приложений и специализированных решений для автоматизации и цифровизации бизнес-процессов и мероприятий любого масштаба.
					p Наш подход основан на глубоком понимании потребностей клиента, использовании современных технологий и строгом соблюдении стандартов качества и информационной безопасности.
				.col-lg-6.wow.fadeInRight(data-wow-delay="0.6s")
					.about-company-facts.p-4.rounded(style="background-color: #f8f9fa;")
						h4.mb-3(style="color: #325db0;") Ключевые факты
						ul.list-unstyled
							li.mb-3.d-flex.align-items-start
								span.fact-icon.mr-3
									svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
										polyline(points="20 6 9 17 4 12")
								div
									strong Аккредитованная ИТ-компания
									small Включены в реестр Минцифры России.
							li.mb-3.d-flex.align-items-start
								span.fact-icon.mr-3
									svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
										path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
										polyline(points="14 2 14 8 20 8")
										line(x1="16", y1="13", x2="8", y2="13")
										line(x1="16", y1="17", x2="8", y2="17")
										polyline(points="10 9 9 9 8 9")
								div
									strong Отечественное ПО
									small Разрабатываемое нами ПО включено в реестр (запись №8664 от 31.12.2020).
							li.mb-3.d-flex.align-items-start
								span.fact-icon.mr-3
									svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
										path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
								div
									strong Лицензия ФСТЭК
									small Деятельность по технической защите конфиденциальной информации (№ Л024-00107-77/01010616).
							li.d-flex.align-items-start
								span.fact-icon.mr-3
									svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
										path(d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2")
										circle(cx="9", cy="7", r="4")
										path(d="M23 21v-2a4 4 0 0 0-3-3.87")
										path(d="M16 3.13a4 4 0 0 1 0 7.75")
								div
									strong Оператор персональных данных
									small Реестр Роскомнадзора (запись №14-0251250 от 03.07.2014).
	// end sAboutCompany
